# BitMEX Exchange Configuration
BITMEX_API_KEY=your_bitmex_api_key_here
BITMEX_API_SECRET=your_bitmex_api_secret_here
BITMEX_TEST_MODE=false

# Dogecoin Mainnet Configuration
DOGECOIN_MAINNET_RPC_URL=http://localhost:22555
DOGECOIN_MAINNET_RPC_USER=dogecoin_user
DOGECOIN_MAINNET_RPC_PASSWORD=dogecoin_password

# Dogecoin Testnet Configuration
DOGECOIN_TESTNET_RPC_URL=http://localhost:44555
DOGECOIN_TESTNET_RPC_USER=dogecoin_user
DOGECOIN_TESTNET_RPC_PASSWORD=dogecoin_password

# Dogecoin Regtest Configuration
DOGECOIN_REGTEST_RPC_URL=http://localhost:18332
DOGECOIN_REGTEST_RPC_USER=dogecoin_user
DOGECOIN_REGTEST_RPC_PASSWORD=dogecoin_password

# Application Settings
NODE_ENV=development
LOG_LEVEL=info
